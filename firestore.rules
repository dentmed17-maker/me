rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "youceffeddag1@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 150 &&
             data.displayName is string && data.displayName.size() >= 0 && data.displayName.size() < 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidAppointment(data) {
      return hasOnlyAllowedFields(['userId', 'userName', 'date', 'status', 'notes', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.userName is string && data.userName.size() >= 0 && data.userName.size() < 100 &&
             data.date is timestamp &&
             data.status in ['pending', 'accepted', 'denied'] &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['senderId', 'receiverId', 'text', 'timestamp', 'read']) &&
             data.senderId is string && data.senderId.size() > 0 && data.senderId.size() < 100 &&
             data.receiverId is string && data.receiverId.size() > 0 && data.receiverId.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.timestamp is timestamp &&
             data.read is bool;
    }

    function isValidShowcase(data) {
      return hasOnlyAllowedFields(['titleAr', 'titleFr', 'descAr', 'descFr', 'imageUrl', 'createdAt']) &&
             data.titleAr is string && data.titleAr.size() > 0 && data.titleAr.size() <= 200 &&
             data.titleFr is string && data.titleFr.size() > 0 && data.titleFr.size() <= 200 &&
             data.descAr is string && data.descAr.size() >= 0 && data.descAr.size() <= 2000 &&
             data.descFr is string && data.descFr.size() >= 0 && data.descFr.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    request.resource.data.uid == request.auth.uid &&
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid &&
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /appointments/{appointmentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && isValidAppointment(request.resource.data) && 
                    request.resource.data.userId == resource.data.userId &&
                    ((isOwner(resource.data.userId) && request.resource.data.status == resource.data.status) || isAdmin());
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isAdmin());
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && 
                    (request.auth.uid == request.resource.data.senderId || isAdmin());
      allow update: if isAuthenticated() && isValidMessage(request.resource.data) && 
                    request.resource.data.senderId == resource.data.senderId &&
                    request.resource.data.receiverId == resource.data.receiverId &&
                    request.resource.data.text == resource.data.text &&
                    request.resource.data.timestamp == resource.data.timestamp &&
                    (request.auth.uid == resource.data.receiverId || isAdmin()); // Only allow updating 'read' status
    }

    match /showcases/{showcaseId} {
      allow read: if true;
      allow create: if isAdmin() && isValidShowcase(request.resource.data);
      allow update: if isAdmin() && isValidShowcase(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
